---
interface Props {
  title: string
  description?: string
  image?: string
  url?: string
  lang?: string
}

const { 
  title, 
  description = "", 
  image = "/perfil.jpg", 
  url = "https://jorgetricarico.com",
  lang = "es"
} = Astro.props

const themeLabels = {
  es: { dark: 'Oscuro', light: 'Claro' },
  en: { dark: 'Dark', light: 'Light' }
}[lang as 'es' | 'en'] || { dark: 'Oscuro', light: 'Claro' };
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" as="image" href={image} />

    <meta property="og:url" content={url} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content={url.split("//")[1] ?? ''} />
    <meta property="twitter:url" content={url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    
    <!-- Umami Analytics -->
    <script defer src="https://cloud.umami.is/script.js" data-website-id="d59a6c31-518c-4004-b635-3d93994a2aa9"></script>

    <script is:inline>
      // Blocking script to prevent FOUC (Flash of Unstyled Content)
      const savedTheme = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const isDark = savedTheme === 'dark' || (!savedTheme && prefersDark);
      if (isDark) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body>
    <div class="ambient-orb orb-1"></div>
    <div class="ambient-orb orb-2"></div>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg-page-edge: #f3f4f6;
    --bg-page-center: #ffffff;
    --bg-card: rgba(255, 255, 255, 0.75);
    --bg-footer: rgba(253, 253, 253, 0.8);
    --text-main: #111;
    --text-muted: #444;
    --shadow-card: 0 0 100px 20px rgba(0, 0, 0, 0.02);
    --animation-duration: 0.8s;
  }

  :root.dark {
    --bg-page-edge: #050505;
    --bg-page-center: #0a0a0a;
    --bg-card: rgba(17, 17, 17, 0.7);
    --bg-footer: rgba(10, 10, 10, 0.8);
    --text-main: #eee;
    --text-muted: #999;
    --shadow-card: 0 0 150px 30px rgba(255, 255, 255, 0.01);
  }

  html {
    font-family:
      Menlo,
      Monaco,
      Lucida Console,
      "Courier New",
      Courier,
      monospace;
    background: var(--bg-page-center);
    letter-spacing: -0.025rem;
    transition: background 0.5s ease;
  }

  .ambient-orb {
    position: fixed;
    border-radius: 50%;
    filter: blur(90px); 
    z-index: 1; 
    pointer-events: none;
    opacity: 0.5; 
    animation: float 8s infinite alternate ease-in-out;
    transition: opacity 0.5s ease, filter 0.5s ease;
  }

  html.dark .ambient-orb {
    opacity: 0.35;
    filter: blur(100px);
  }

  .orb-1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, #60a5fa 0%, transparent 70%);
    top: -200px;
    left: -200px;
  }

  .orb-2 {
    width: 550px;
    height: 550px;
    background: radial-gradient(circle, #c084fc 0%, transparent 70%);
    bottom: -150px;
    right: -150px;
    animation-delay: -3s;
    animation-duration: 10s;
  }

  @keyframes float {
    0% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(100px, 150px) scale(1.2); }
    66% { transform: translate(-50px, 250px) scale(0.8); }
    100% { transform: translate(20px, 50px) scale(1.1); }
  }

  body,
  figure {
    margin: 0;
    padding: 0;
  }

  a {
    text-decoration: none;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  h1,
  h2,
  h3,
  h4 {
    margin: 0;
    color: var(--text-main);
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
  }

  p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
    text-wrap: pretty;
  }

  .print {
    display: none !important;
  }

  @media print {
    .no-print {
      display: none !important;
    }

    .print {
      display: block !important;
    }

    astro-dev-toolbar {
      display: none !important;
    }

    article {
      break-inside: avoid;
    }

    html, html.dark {
      background: #fff !important;
      filter: none !important;
    }
    html.dark img, html.dark video {
      filter: none !important;
    }

    body {
      background: #fff !important;
    }

    html {
      font-size: 11px;
    }

    body, main {
      padding: 0 !important;
      margin: 0 !important;
    }

    main {
      padding: 0.5rem 1rem !important;
    }

    h1 { font-size: 1.4rem !important; }
    h2 { font-size: 1rem !important; margin-bottom: 0.15rem !important; }
    h3 { font-size: 0.9rem !important; }

    p {
      font-size: 0.78rem !important;
      line-height: 1.3 !important;
    }

    section {
      margin-bottom: 0.4rem !important;
    }

    ul {
      margin-bottom: 0.2rem !important;
    }

    li {
      margin-bottom: 0.1rem !important;
    }
  }

  html.dark body {
    color: var(--text-main);
  }

  #theme-toggle {
    position: fixed;
    top: 16px;
    right: 20px;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px 7px 10px;
    background: rgba(255, 255, 255, 0.75);
    border: 1px solid rgba(251, 191, 36, 0.4);
    border-radius: 999px;
    cursor: pointer;
    z-index: 9999;
    font-size: 0.8rem;
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    color: #333;
    letter-spacing: 0.01em;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 0 20px rgba(251, 191, 36, 0.4);
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
  }

  html.dark #theme-toggle {
    background: rgba(30, 30, 30, 0.75);
    border: 1px solid rgba(167, 139, 250, 0.5); /* Moonlight border */
    color: #eee;
    box-shadow: 0 0 25px rgba(167, 139, 250, 0.35); /* Soft purple/blue glow */
  }

  #theme-toggle:hover {
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 0 35px rgba(251, 191, 36, 0.8);
    transform: translateY(-1px);
  }

  html.dark #theme-toggle:hover {
    background: rgba(45, 45, 45, 0.95);
    box-shadow: 0 0 45px rgba(167, 139, 250, 0.6);
  }

  #theme-toggle:active {
    transform: translateY(0);
  }

  #theme-toggle svg {
    transition: transform 0.4s ease, filter 0.3s ease;
    overflow: visible !important;
    -webkit-filter: drop-shadow(0 0 10px rgba(251, 191, 36, 1)); /* Stronger sun glow */
    filter: drop-shadow(0 0 10px rgba(251, 191, 36, 1));
    color: #f59e0b;
  }

  html.dark #theme-toggle svg {
    -webkit-filter: drop-shadow(0 0 12px rgba(255, 255, 255, 0.8)); /* Stronger moon glow */
    filter: drop-shadow(0 0 12px rgba(255, 255, 255, 0.8));
    color: #f3f4f6;
  }

  #theme-toggle:hover svg {
    transform: rotate(20deg) scale(1.1);
  }
</style>

<button 
  id="theme-toggle" 
  class="no-print" 
  aria-label="Toggle Dark Mode"
  data-labels={JSON.stringify(themeLabels)}
>
  <svg id="toggle-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>
  <span id="toggle-label">{themeLabels.light}</span>
</button>

<script>
  const themeToggle = document.getElementById('theme-toggle');
  const toggleLabel = document.getElementById('toggle-label');
  const toggleIcon = document.getElementById('toggle-icon');
  
  const labels = JSON.parse(themeToggle?.dataset.labels || '{"dark":"Oscuro","light":"Claro"}');

  const updateThemeUI = (isDark: boolean) => {
    if (toggleLabel) toggleLabel.textContent = isDark ? labels.dark : labels.light;
    if (toggleIcon) {
      toggleIcon.innerHTML = isDark 
        ? '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>' // Moon icon
        : '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>'; // Sun icon
    }
  };

  if (themeToggle) {
    themeToggle.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateThemeUI(isDark);
    });

    const savedTheme = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const isDark = savedTheme === 'dark' || (!savedTheme && prefersDark);
    
    // UI already handled by inline blocking script for class,
    // but we need to update the button text and icon.
    updateThemeUI(isDark);
  }

  let closedDetails: HTMLDetailsElement[] = [];

  window.addEventListener('beforeprint', () => {
    closedDetails = [];
    document.querySelectorAll<HTMLDetailsElement>('details').forEach((el) => {
      if (!el.open) {
        closedDetails.push(el);
        el.open = true;
      }
    });
  });

  window.addEventListener('afterprint', () => {
    closedDetails.forEach((el) => {
      el.open = false;
    });
    closedDetails = [];
  });
</script>
