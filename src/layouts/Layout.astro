---
interface Props {
  title: string
  description?: string
  image?: string
  url?: string
  lang?: string
}

const { 
  title, 
  description = "", 
  image = "/perfil.jpg", 
  url = "https://jorgetricarico.com",
  lang = "es"
} = Astro.props

const themeLabels = {
  es: { dark: 'Oscuro', light: 'Claro' },
  en: { dark: 'Dark', light: 'Light' }
}[lang as 'es' | 'en'] || { dark: 'Oscuro', light: 'Claro' };
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" as="image" href={image} />

    <meta property="og:url" content={url} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content={url.split("//")[1] ?? ''} />
    <meta property="twitter:url" content={url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    
    <!-- Umami Analytics -->
    <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="d59a6c31-518c-4004-b635-3d93994a2aa9" data-domains="jorgetricarico.com"></script>

    <script is:inline>
      // Blocking script to prevent FOUC (Flash of Unstyled Content)
      const savedTheme = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const isDark = savedTheme === 'dark' || (!savedTheme && prefersDark);
      if (isDark) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body>
    <div class="ambient-orb orb-1"></div>
    <div class="ambient-orb orb-2"></div>
    <div class="bug-container no-print">
      <canvas id="explosion-canvas" class="explosion-canvas"></canvas>
      <div class="bug-target" id="bug-1">
        <div class="bug-crosshair"></div>
        <div class="bug-body">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M8 3 4 7M16 3l4 4M4 11h4M16 11h4M4 15l4 4M16 15l4 4"/>
            <path d="M12 20v-9M6.5 12a5.5 5.5 0 1 1 11 0v4a5.5 5.5 0 1 1-11 0v-4Z"/>
            <path d="M12 10a2 2 0 0 0-2-2M12 10a2 2 0 0 1 2-2"/>
          </svg>
        </div>
      </div>
      <div class="bug-target" id="bug-2">
        <div class="bug-crosshair"></div>
        <div class="bug-body">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M8 3 4 7M16 3l4 4M4 11h4M16 11h4M4 15l4 4M16 15l4 4"/>
            <path d="M12 20v-9M6.5 12a5.5 5.5 0 1 1 11 0v4a5.5 5.5 0 1 1-11 0v-4Z"/>
            <path d="M12 10a2 2 0 0 0-2-2M12 10a2 2 0 0 1 2-2"/>
          </svg>
        </div>
      </div>
      <div class="bug-target" id="bug-3">
        <div class="bug-crosshair"></div>
        <div class="bug-body">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M8 3 4 7M16 3l4 4M4 11h4M16 11h4M4 15l4 4M16 15l4 4"/>
            <path d="M12 20v-9M6.5 12a5.5 5.5 0 1 1 11 0v4a5.5 5.5 0 1 1-11 0v-4Z"/>
            <path d="M12 10a2 2 0 0 0-2-2M12 10a2 2 0 0 1 2-2"/>
          </svg>
        </div>
      </div>
    </div>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg-page-edge: #f3f4f6;
    --bg-page-center: #ffffff;
    --bg-card: rgba(255, 255, 255, 0.75);
    --bg-footer: rgba(253, 253, 253, 0.8);
    --text-main: #111;
    --text-muted: #444;
    --shadow-card: 0 0 100px 20px rgba(0, 0, 0, 0.02);
    --animation-duration: 0.8s;
  }

  :root.dark {
    --bg-page-edge: #050505;
    --bg-page-center: #0a0a0a;
    --bg-card: rgba(17, 17, 17, 0.7);
    --bg-footer: rgba(10, 10, 10, 0.8);
    --text-main: #eee;
    --text-muted: #999;
    --shadow-card: 0 0 150px 30px rgba(255, 255, 255, 0.01);
  }

  html {
    font-family:
      Menlo,
      Monaco,
      Lucida Console,
      "Courier New",
      Courier,
      monospace;
    background: var(--bg-page-center);
    letter-spacing: -0.025rem;
    transition: background 0.5s ease;
  }

  .ambient-orb {
    position: fixed;
    border-radius: 50%;
    filter: blur(90px); 
    z-index: 1; 
    pointer-events: none;
    opacity: 0.5; 
    animation: float 8s infinite alternate ease-in-out;
    transition: opacity 0.5s ease, filter 0.5s ease;
  }

  html.dark .ambient-orb {
    opacity: 0.35;
    filter: blur(100px);
  }

  .orb-1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, #60a5fa 0%, transparent 70%);
    top: -200px;
    left: -200px;
  }

  .orb-2 {
    width: 550px;
    height: 550px;
    background: radial-gradient(circle, #c084fc 0%, transparent 70%);
    bottom: -150px;
    right: -150px;
    animation-delay: -3s;
    animation-duration: 10s;
  }

  @keyframes float {
    0% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(100px, 150px) scale(1.2); }
    66% { transform: translate(-50px, 250px) scale(0.8); }
    100% { transform: translate(20px, 50px) scale(1.1); }
  }

  .bug-target {
    position: fixed;
    z-index: 1000;
    pointer-events: auto;
    opacity: 0.12;
    color: #60a5fa;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.5s ease, color 0.3s ease;
    cursor: crosshair;
    user-select: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  html.dark .bug-target {
    color: #a78bfa;
    opacity: 0.18;
  }

  .bug-target:hover {
    opacity: 0.3;
  }

  .bug-target.squashed {
    opacity: 0.6;
    color: #f87171 !important;
    filter: drop-shadow(0 0 8px rgba(248, 113, 113, 0.4));
    pointer-events: none;
  }

  .bug-body {
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .bug-target.targeting .bug-crosshair {
    display: block;
    animation: pulse-crosshair 0.4s ease-out forwards;
  }

  .bug-target.squashed .bug-body {
    transform: scale(0.5);
    opacity: 0;
    transition: all 0.3s ease-out;
  }

  .bug-target.squashed .bug-crosshair {
    display: block;
    opacity: 0.3;
    transform: scale(0.8);
  }

  .explosion-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1000000; /* Above overlay (99999) but below bugs (1000001) */
  }

  .bug-crosshair {
    position: absolute;
    width: 28px;
    height: 28px;
    border: 0.5px solid rgba(248, 113, 113, 0.6);
    border-radius: 50%;
    pointer-events: none;
    display: none;
  }

  .bug-crosshair::before, .bug-crosshair::after {
    content: '';
    position: absolute;
    background: rgba(248, 113, 113, 0.6);
  }

  .bug-crosshair::before {
    top: 50%;
    left: -15%;
    width: 130%;
    height: 0.5px;
    transform: translateY(-50%);
  }

  .bug-crosshair::after {
    left: 50%;
    top: -15%;
    height: 130%;
    width: 0.5px;
    transform: translateX(-50%);
  }

  @keyframes pulse-crosshair {
    0% { transform: scale(0.5); opacity: 0; }
    50% { transform: scale(1.2); opacity: 1; }
    100% { transform: scale(1); opacity: 0.8; }
  }

  body,
  figure {
    margin: 0;
    padding: 0;
  }

  a {
    text-decoration: none;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  h1,
  h2,
  h3,
  h4 {
    margin: 0;
    color: var(--text-main);
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
  }

  p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
    text-wrap: pretty;
  }

  .print {
    display: none !important;
  }

  @media print {
    .no-print {
      display: none !important;
    }

    .print {
      display: block !important;
    }

    astro-dev-toolbar {
      display: none !important;
    }

    article {
      break-inside: avoid;
    }

    html, html.dark {
      background: #fff !important;
      filter: none !important;
    }
    html.dark img, html.dark video {
      filter: none !important;
    }

    body {
      background: #fff !important;
    }

    html {
      font-size: 11px;
    }

    body, main {
      padding: 0 !important;
      margin: 0 !important;
    }

    main {
      padding: 0.5rem 1rem !important;
    }

    h1 { font-size: 1.4rem !important; }
    h2 { font-size: 1rem !important; margin-bottom: 0.15rem !important; }
    h3 { font-size: 0.9rem !important; }

    p {
      font-size: 0.78rem !important;
      line-height: 1.3 !important;
    }

    section {
      margin-bottom: 0.4rem !important;
    }

    ul {
      margin-bottom: 0.2rem !important;
    }

    li {
      margin-bottom: 0.1rem !important;
    }
  }

  html.dark body {
    color: var(--text-main);
  }

  #theme-toggle {
    position: absolute;
    top: 16px;
    right: 20px;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px 7px 10px;
    background: rgba(255, 255, 255, 0.75);
    border: 1px solid rgba(251, 191, 36, 0.4);
    border-radius: 999px;
    cursor: pointer;
    z-index: 9999;
    font-size: 0.8rem;
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 500;
    color: #333;
    letter-spacing: 0.01em;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 0 20px rgba(251, 191, 36, 0.4);
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
  }

  html.dark #theme-toggle {
    background: rgba(30, 30, 30, 0.75);
    border: 1px solid rgba(167, 139, 250, 0.5); /* Moonlight border */
    color: #eee;
    box-shadow: 0 0 25px rgba(167, 139, 250, 0.35); /* Soft purple/blue glow */
  }

  #theme-toggle:hover {
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 0 35px rgba(251, 191, 36, 0.8);
    transform: translateY(-1px);
  }

  html.dark #theme-toggle:hover {
    background: rgba(45, 45, 45, 0.95);
    box-shadow: 0 0 45px rgba(167, 139, 250, 0.6);
  }

  #theme-toggle:active {
    transform: translateY(0);
  }

  #theme-toggle svg {
    transition: transform 0.4s ease, filter 0.3s ease;
    overflow: visible !important;
    -webkit-filter: drop-shadow(0 0 10px rgba(251, 191, 36, 1)); /* Stronger sun glow */
    filter: drop-shadow(0 0 10px rgba(251, 191, 36, 1));
    color: #f59e0b;
  }

  html.dark #theme-toggle svg {
    -webkit-filter: drop-shadow(0 0 12px rgba(255, 255, 255, 0.8)); /* Stronger moon glow */
    filter: drop-shadow(0 0 12px rgba(255, 255, 255, 0.8));
    color: #f3f4f6;
  }

  #theme-toggle:hover svg {
    transform: rotate(20deg) scale(1.1);
  }
</style>

<button 
  id="theme-toggle" 
  class="no-print" 
  aria-label="Toggle Dark Mode"
  data-labels={JSON.stringify(themeLabels)}
>
  <svg id="toggle-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>
  <span id="toggle-label">{themeLabels.light}</span>
</button>

<script>
  const themeToggle = document.getElementById('theme-toggle');
  const toggleLabel = document.getElementById('toggle-label');
  const toggleIcon = document.getElementById('toggle-icon');
  
  const labels = JSON.parse(themeToggle?.dataset.labels || '{"dark":"Oscuro","light":"Claro"}');

  const updateThemeUI = (isDark: boolean) => {
    if (toggleLabel) toggleLabel.textContent = isDark ? labels.dark : labels.light;
    if (toggleIcon) {
      toggleIcon.innerHTML = isDark 
        ? '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>' // Moon icon
        : '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>'; // Sun icon
    }
  };

  if (themeToggle) {
    themeToggle.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateThemeUI(isDark);
      
      // Dispatch custom event for other components (like hotkeypad) to react
      window.dispatchEvent(new CustomEvent('theme-changed', { detail: { theme: isDark ? 'dark' : 'light' } }));
    });

    const savedTheme = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const isDark = savedTheme === 'dark' || (!savedTheme && prefersDark);
    updateThemeUI(isDark);
  }

  // Bug Squash Logic
  const bugs = document.querySelectorAll('.bug-target');
  const canvas = document.getElementById('explosion-canvas') as HTMLCanvasElement;
  const ctx = canvas?.getContext('2d');
  let particles: any[] = [];

  const resize = () => {
    if (canvas) {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }
  };
  window.addEventListener('resize', resize);
  resize();

  class Particle {
    x: number; y: number; vx: number; vy: number; life: number; color: string; size: number; friction: number; gravity: number;
    constructor(x: number, y: number, color: string) {
      this.x = x;
      this.y = y;
      const angle = Math.random() * Math.PI * 2;
      const speed = Math.random() * 2 + 1; // Slower speed
      this.vx = Math.cos(angle) * speed;
      this.vy = Math.sin(angle) * speed;
      this.life = 1.0;
      this.color = color;
      this.size = Math.random() * 1.5 + 0.5; // Smaller size
      this.friction = 0.94; // Higher friction to slow down faster
      this.gravity = 0.05; // Lower gravity for a floating feel
    }
    update() {
      this.vx *= this.friction;
      this.vy *= this.friction;
      this.vy += this.gravity;
      this.x += this.vx;
      this.y += this.vy;
      this.life -= 0.01; // Slower fade
    }
    draw() {
      if (!ctx) return;
      ctx.fillStyle = this.color;
      ctx.globalAlpha = this.life;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
      ctx.fill();
      // Add a slight glow
      ctx.shadowBlur = 5;
      ctx.shadowColor = this.color;
    }
  }

  const animate = () => {
    if (!ctx || !canvas) return;
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    particles = particles.filter(p => p.life > 0);
    particles.forEach(p => {
      p.update();
      p.draw();
    });
    requestAnimationFrame(animate);
  };
  animate();

  const spawnExplosion = (x: number, y: number) => {
    const colors = ['#60a5fa', '#a78bfa', '#ffffff', '#ef4444']; // Tech palette + alert red
    for (let i = 0; i < 20; i++) { // Fewer particles
      const color = colors[Math.floor(Math.random() * colors.length)];
      particles.push(new Particle(x, y, color));
    }
  };
  (window as any).spawnExplosion = spawnExplosion;

  bugs.forEach((bug) => {
    let x = Math.random() * (window.innerWidth - 50);
    let y = Math.random() * (window.innerHeight - 50);
    let dx = (Math.random() - 0.5) * 1.5;
    let dy = (Math.random() - 0.5) * 1.5;

    const move = () => {
      if (bug.classList.contains('squashed') || bug.classList.contains('targeting')) return;

      x += dx;
      y += dy;

      if (x <= 10 || x >= window.innerWidth - 40) dx *= -1;
      if (y <= 10 || y >= window.innerHeight - 40) dy *= -1;

      (bug as HTMLElement).style.left = `${x}px`;
      (bug as HTMLElement).style.top = `${y}px`;
      (bug as HTMLElement).style.transform = `rotate(${Math.atan2(dy, dx) + Math.PI / 2}rad)`;

      requestAnimationFrame(move);
    };

    bug.addEventListener('click', () => {
      if (bug.classList.contains('targeting')) return;
      
      bug.classList.add('targeting');
      
      setTimeout(() => {
        bug.classList.remove('targeting');
        bug.classList.add('squashed');
        
        const rect = bug.getBoundingClientRect();
        spawnExplosion(rect.left + rect.width / 2, rect.top + rect.height / 2);
        
        setTimeout(() => {
          bug.classList.remove('squashed');
          x = Math.random() * (window.innerWidth - 50);
          y = Math.random() * (window.innerHeight - 50);
          dx = (Math.random() - 0.5) * 1.5;
          dy = (Math.random() - 0.5) * 1.5;
          move();
        }, 3000);
      }, 300);
    });

    move();
  });

  let closedDetails: HTMLDetailsElement[] = [];

  window.addEventListener('beforeprint', () => {
    closedDetails = [];
    document.querySelectorAll<HTMLDetailsElement>('details').forEach((el) => {
      if (!el.open) {
        closedDetails.push(el);
        el.open = true;
      }
    });
  });

  window.addEventListener('afterprint', () => {
    closedDetails.forEach((el) => {
      el.open = false;
    });
    closedDetails = [];
  });
</script>
