---
const { currentLang } = Astro.props;
const isEn = currentLang === 'en';
---

<div class="language-switch-container no-print">
  <a href={isEn ? "/" : "/en"} class="language-switch" aria-label="Toggle Language">
    <div class={`switch-thumb ${isEn ? 'is-en' : 'is-es'}`}></div>
    <span class="label es">ES</span>
    <span class="label en">EN</span>
  </a>
</div>

<style>
  .language-switch-container {
    position: absolute;
    top: 20px;
    left: 20px;
    z-index: 10000;
  }

  .language-switch {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 64px;
    height: 32px;
    background: rgba(255, 255, 255, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 100px;
    padding: 4px;
    position: relative;
    text-decoration: none;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    transition: all 0.3s ease;
    cursor: pointer;
  }

  html.dark .language-switch {
    background: rgba(15, 15, 15, 0.4);
    border-color: rgba(255, 255, 255, 0.05);
  }

  .switch-thumb {
    position: absolute;
    top: 3px;
    left: 3px;
    width: 26px;
    height: 24px;
    background: linear-gradient(135deg, #60a5fa 0%, #c084fc 100%);
    border-radius: 100px;
    transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    z-index: 1;
    box-shadow: 0 2px 8px rgba(96, 165, 250, 0.3);
  }

  .switch-thumb.is-en {
    transform: translateX(30px);
  }

  .label {
    flex: 1;
    text-align: center;
    font-size: 0.65rem;
    font-weight: 800;
    color: var(--text-muted);
    z-index: 2;
    transition: color 0.3s ease;
    pointer-events: none;
    user-select: none;
  }

  .label.es {
    margin-right: 2px;
  }

  .label.en {
    margin-left: 2px;
  }

  .is-es ~ .es { color: white; }
  .is-en ~ .en { color: white; }

  .language-switch:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
  }
</style>
