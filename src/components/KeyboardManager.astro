---
import 'hotkeypad/reset.css'
import 'hotkeypad/index.css'
import { type SocialIcon } from "@/types"
import { ui } from "@/i18n"
import type { CV } from "@/cv"

interface Props {
  cv: CV
  lang?: string
}

const { cv, lang = 'es' } = Astro.props
const { profiles } = cv.basics
const t = ui[lang as keyof typeof ui]

const SOCIAL_ICONS: SocialIcon = {
  GitHub: `<svg width="16" height="16" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="margin-right: 8px"><path fill="currentColor" d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"></path></svg>`,
  LinkedIn: `<svg height="16" width="16" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="margin-right: 8px"><title>LinkedIn</title><path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg>`,
  X: `<svg width="16" height="16" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="margin-right: 8px"><title>X</title><path fill="currentColor" d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"></path></svg>`
}

const profilesInfo = profiles.map(({ network, url }) => {
  const icon = SOCIAL_ICONS[network as keyof typeof SOCIAL_ICONS]
  const firstLetter = network[0].toUpperCase()

  return {
    id: network,
    section: t['keyboard.social'],
    title: `${t['hero.visit']} ${network}`,
    url,
    icon,
    hotkey: `ctrl+${firstLetter}`
  }
})

const pdfPath = lang === 'en' ? "/cv_en.pdf" : "/cv.pdf";
---

<footer id="normal-footer" class="no-print">
  {t['keyboard.mod']} <kbd id="mod-key">Ctrl</kbd> + <kbd>K</kbd> {t['keyboard.open']}.
</footer>

<div id="footer-button" class="no-print">
  <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-command" width="32" height="32" viewBox="0 0 24 24" stroke-width="1.5" stroke="#777" fill="none" stroke-linecap="round" stroke-linejoin="round">
    <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
    <path d="M7 9a2 2 0 1 1 2 -2v10a2 2 0 1 1 -2 -2h10a2 2 0 1 1 -2 2v-10a2 2 0 1 1 2 2h-10"></path>
  </svg>
</div>

<div
  id="hotkeypad"
  data-placeholder={t['keyboard.placeholder']}
  data-info={JSON.stringify(profilesInfo)}
  data-pdf={pdfPath}
  data-download-text={t['keyboard.download']}
  data-actions-text={t['keyboard.actions']}
  data-toggle-theme={t['command.toggle_theme']}
  data-toggle-lang={t['command.toggle_lang']}
  data-copy-email={t['command.copy_email']}
  data-scroll-top={t['command.scroll_top']}
  data-email-copied={t['command.email_copied']}
  data-email={cv.basics.email}
>
</div>

<script>
  interface Info {
    id: string
    section: string
    title: string
    url: string
    icon: string
    hotkey: string
    handler?: () => void
  }

  import HotKeyPad from "hotkeypad"

  const hotkeypad = new HotKeyPad()
  const el = hotkeypad.instance;
  const info = el.getAttribute("data-info") ?? "[]"
  const pdfPath = el.getAttribute("data-pdf") ?? "/cv.pdf"
  const downloadText = el.getAttribute("data-download-text") ?? "Download CV"
  const actionsText = el.getAttribute("data-actions-text") ?? "Actions"
  const parsedInfo = JSON.parse(info) as Info[]

  const data = parsedInfo.map(
    ({ url, hotkey, icon, id, section, title }) => {
      return {
        id,
        title,
        icon,
        hotkey,
        section,
        handler: () => {
          window.open(url, "_blank")
        }
      }
    }
  )

  const t = {
    toggle_theme: el.getAttribute("data-toggle-theme") ?? "Toggle Theme",
    toggle_lang: el.getAttribute("data-toggle-lang") ?? "Toggle Language",
    copy_email: el.getAttribute("data-copy-email") ?? "Copy Email",
    scroll_top: el.getAttribute("data-scroll-top") ?? "Scroll to Top",
    email_copied: el.getAttribute("data-email-copied") ?? "Email copied!",
    email: el.getAttribute("data-email") ?? ""
  }

  hotkeypad.setCommands([
    {
      id: "print",
      title: downloadText,
      icon: `<svg style="margin-right: 8px" width="16" height="16" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
  <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
</svg>`,
      hotkey: "ctrl+P",
      section: actionsText,
      handler: () => {
        window.open(pdfPath, "_blank")
      }
    },
    {
      id: "toggle-theme",
      title: t.toggle_theme,
      icon: `<svg style="margin-right: 8px" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>`,
      hotkey: "ctrl+D",
      section: actionsText,
      handler: () => {
        const themeBtn = document.getElementById('theme-toggle');
        themeBtn?.click();
      }
    },
    {
      id: "toggle-lang",
      title: t.toggle_lang,
      icon: `<svg style="margin-right: 8px" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 5h12M7 2h1M7 5c0 4.418-2.239 8-5 8M2 7c0 4.418 2.239 8 5 8M14 22l4-10 4 10M15 18h6"/></svg>`,
      hotkey: "ctrl+L",
      section: actionsText,
      handler: () => {
        const langSwitch = document.querySelector('.language-switch') as HTMLAnchorElement;
        langSwitch?.click();
      }
    },
    {
      id: "copy-email",
      title: t.copy_email,
      icon: `<svg style="margin-right: 8px" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="m22 6-10 7L2 6"/></svg>`,
      hotkey: "ctrl+E",
      section: actionsText,
      handler: () => {
        if (t.email) {
            navigator.clipboard.writeText(t.email);
            alert(t.email_copied);
        }
      }
    },
    {
      id: "scroll-top",
      title: t.scroll_top,
      icon: `<svg style="margin-right: 8px" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m18 15-6-6-6 6"/></svg>`,
      hotkey: "ctrl+UP",
      section: actionsText,
      handler: () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    },
    ...data
  ])

  const isMac = /Mac|iPhone|iPod|iPad/i.test(navigator.userAgent)
  const modKeyEl = document.getElementById('mod-key')
  if (modKeyEl) {
    modKeyEl.textContent = isMac ? 'Cmd' : 'Ctrl'
  }

  const footerButton = document.getElementById("footer-button")
  footerButton?.addEventListener("click", () => {
    var event = new KeyboardEvent("keydown", {
      key: "k",
      code: "KeyK",
      keyCode: 75,
      which: 75,
      ctrlKey: !isMac,
      altKey: false,
      shiftKey: false,
      metaKey: isMac
    })

    document.dispatchEvent(event)
  })
</script>

<style>
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  @media (min-width: 601px) {
    #normal-footer { display: block; }
    #footer-button { display: none; }
  }

  @media (max-width: 600px) {
    #normal-footer { display: none; }
    #footer-button {
      background: #fff;
      position: fixed;
      border: 1px solid #eee;
      right: 10px;
      bottom: 10px;
      width: 50px;
      height: 50px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
    }
  }

  footer {
    background: var(--bg-footer);
    color: var(--text-main);
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    position: fixed;
    bottom: 0px;
    width: 100%;
    padding-block: 8px;
    text-align: center;
    font-size: 0.85rem;
    z-index: 100;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    animation: linear 0.3s fadeIn;
  }

  html.dark footer { border-top: 1px solid rgba(255, 255, 255, 0.1); }

  kbd {
    background: rgba(0, 0, 0, 0.05);
    color: var(--text-main);
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 4px;
    padding: 2px 4px;
    font-size: 12px;
  }

  html.dark kbd {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  /* Hotkeypad Dark Mode & Custom Styles */
  :global(#hotkeypad [data-wrapper]) {
    background: rgba(255, 255, 255, 0.8) !important;
    backdrop-filter: blur(16px) !important;
    -webkit-backdrop-filter: blur(16px) !important;
    border: 1px solid rgba(0, 0, 0, 0.1) !important;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1) !important;
  }

  :global(html.dark #hotkeypad [data-wrapper]) {
    background: rgba(15, 15, 15, 0.8) !important;
    border: 1px solid rgba(255, 255, 255, 0.1) !important;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3) !important;
  }

  :global(#hotkeypad [data-backdrop]) {
    backdrop-filter: blur(4px) !important;
    -webkit-backdrop-filter: blur(4px) !important;
    background: rgba(0, 0, 0, 0.2) !important;
  }

  :global(html.dark #hotkeypad [data-backdrop]) {
    background: rgba(0, 0, 0, 0.6) !important;
  }

  :global(#hotkeypad [data-section]) {
    color: #666 !important;
    font-size: 11px !important;
    text-transform: uppercase !important;
    letter-spacing: 0.05em !important;
  }

  :global(html.dark #hotkeypad [data-section]) {
    color: #999 !important;
  }

  :global(#hotkeypad [data-item][data-active="true"]) {
    background: rgba(96, 165, 250, 0.1) !important;
  }

  :global(html.dark #hotkeypad [data-item][data-active="true"]) {
    background: rgba(167, 139, 250, 0.15) !important;
  }

  :global(#hotkeypad [data-title]) {
    color: var(--text-main) !important;
  }

  :global(#hotkeypad kbd) {
    border: 1px solid rgba(0,0,0,0.1) !important;
    background: rgba(0,0,0,0.05) !important;
    color: #666 !important;
  }

  :global(html.dark #hotkeypad kbd) {
    border: 1px solid rgba(255,255,255,0.1) !important;
    background: rgba(255,255,255,0.1) !important;
    color: #aaa !important;
  }
</style>
