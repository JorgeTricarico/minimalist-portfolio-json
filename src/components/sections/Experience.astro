---
import Section from "../Section.astro"

import { work } from "@cv"
---

<Section title="Experiencia laboral">
  <ul>
    {
      work.map(
        ({ name, startDate, endDate, position, summary, highlights, url }) => {
          const startYear = new Date(startDate).getFullYear()
          const endYear =
            endDate != null ? new Date(endDate).getFullYear() : "Actual"

          // Calcular duración
          const start = new Date(startDate)
          const end = endDate != null ? new Date(endDate) : new Date()
          const totalMonths = (end.getFullYear() - start.getFullYear()) * 12 + (end.getMonth() - start.getMonth())
          const years = Math.floor(totalMonths / 12)
          const months = totalMonths % 12
          const duration = `${years > 0 ? `${years} año${years > 1 ? 's' : ''}` : ''} ${months > 0 ? `${months} mes${months > 1 ? 'es' : ''}` : ''}`.trim()

          return (
            <li>
              <article>
                <details>
                    <summary>
                    <header>
                      <div>
                        <div class="title-container">
                          <h3>
                            {url ? (
                              <a href={url} title={`Ver ${name}`} target="_blank">
                                {name}
                              </a>
                            ) : (
                              name
                            )}
                          </h3>
                          <svg class="chevron-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                        </div>
                        <h4>{position}</h4>
                      </div>

                      <div>
                        <time 
                          datetime={startDate}
                          data-title={startDate}>
                            {startYear}
                        </time>
                        {" - "}
                        <time 
                          datetime={endDate}
                          data-title={endDate}>
                            {endYear}
                        </time>
                      </div>
                    </header>
                    <span class="duration">{duration}</span>
                  </summary>

                  <footer>
                    {summary && <p set:html={summary}></p>}
                    {highlights && (
                      <ul>
                        {highlights.map((highlight) => (
                          <li set:html={highlight.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')}></li>
                        ))}
                      </ul>
                    )}
                  </footer>
                </details>
              </article>
            </li>
          )
        }
      )
    }
  </ul>
</Section>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  summary {
    list-style: none;
    cursor: pointer;
    transition: background 0.3s ease, transform 0.2s ease;
    padding: 12px;
    margin: -12px;
    border-radius: 12px;
    position: relative;
  }

  summary:hover {
    background: rgba(0, 0, 0, 0.02);
  }

  :global(.dark) summary:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  summary:active {
    transform: scale(0.995);
  }

  summary::-webkit-details-marker {
    display: none;
  }

  .title-container {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .chevron-icon {
    color: var(--text-muted);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0.4;
    /* Animación de entrada inicial */
    animation: entrance 0.8s ease-out backwards;
    animation-delay: 0.5s;
  }

  @keyframes entrance {
    from { opacity: 0; transform: scale(0.5) rotate(-90deg); }
    to { opacity: 0.4; transform: scale(1) rotate(0deg); }
  }

  details[open] .chevron-icon {
    transform: rotate(180deg);
    opacity: 0.8;
    color: var(--text-main);
  }

  /* Animación periódica para mobile para "avisar" que es clickeable */
  @media (hover: none) {
    .chevron-icon {
      animation: nudge 3s infinite ease-in-out;
    }
  }

  summary:hover .chevron-icon {
    opacity: 0.9;
    color: var(--text-main);
    animation: bounce 0.6s infinite alternate ease-in-out;
  }

  details[open] summary:hover .chevron-icon {
    animation: bounceOpen 0.6s infinite alternate ease-in-out;
  }

  @keyframes nudge {
    0%, 80%, 100% { transform: translateY(0); }
    85% { transform: translateY(4px); }
    90% { transform: translateY(0); }
    95% { transform: translateY(4px); }
  }

  @keyframes bounce {
    from { transform: translateY(0); }
    to { transform: translateY(3px); }
  }

  @keyframes bounceOpen {
    from { transform: rotate(180deg) translateY(0); }
    to { transform: rotate(180deg) translateY(-3px); }
  }

  footer {
    padding-top: 12px;
    color: var(--text-muted);
    font-size: 0.9rem;
    animation: slideDown 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @keyframes slideDown {
    from { 
      opacity: 0; 
      transform: translateY(-8px);
    }
    to { 
      opacity: 1; 
      transform: translateY(0);
    }
  }

  footer ul {
    list-style-type: disc;
    padding-left: 20px;
    gap: 8px;
  }

  .duration {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 2px;
    display: block;
    opacity: 0.8;
  }

  article h3 {
    font-weight: 500;
    color: var(--text-main);
  }

  article a {
    color: var(--text-main);
  }

  article a:hover {
    text-decoration: underline;
  }

  article h4 {
    color: var(--text-main);
    font-weight: 400;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4px;
  }

  time {
    color: var(--text-muted);
    font-size: 0.85rem;
    min-width: 102px;
    cursor: default;
  }

  [data-title]:hover:after {
    opacity: 1;
    transition: all 0.1s ease-in-out 0.5s;
    visibility: visible;
  }

  [data-title]:after {
    content: attr(data-title);
    background-color: #333;
    color: #fff;
    font-size: .75rem;
    font-family: Menlo, Monaco, Lucida Console, "Courier New", monospace;;
    position: absolute;
    padding: .2rem .5rem;
    bottom: -1.4rem;
    left: 50%;
    white-space: nowrap;
    box-shadow: 1px 1px 1px #222222;
    opacity: 0;
    border: 1px solid #111111;
    z-index: 99999;
    visibility: hidden;
    border-radius: 6px;
  }

  [data-title] {
    position: relative;
  }

  @media (width <= 700px) {
    time {
      text-align: right;
    }
  }

  @media print {
    .chevron-icon {
      display: none;
    }

    /* Force all details open so descriptions are visible */
    details {
      display: block !important;
    }

    details > footer {
      display: block !important;
    }

    /* Compact spacing for print */
    ul {
      gap: 12px !important;
    }

    footer {
      padding-top: 4px !important;
      animation: none !important;
    }
  }
</style>
