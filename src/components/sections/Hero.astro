---
import { basics as defaultBasics } from "@cv"
import Section from "@/components/Section.astro"
import Mail from "@/icons/Mail.astro"
import Phone from "@/icons/Phone.astro"
import WhatsApp from "@/icons/WhatsApp.astro"
import X from "@/icons/X.astro"
import LinkedIn from "@/icons/LinkedIn.astro"
import GitHub from "@/icons/GitHub.astro"
import WorldMap from "@/icons/WorldMap.astro"
import Download from "@/icons/Download.astro"
import type { SocialIcon } from "@/types"
import type { Basics } from "@/cv"
import { ui } from "@/i18n"

interface Props {
  basics?: Basics
  lang?: string
}

const { basics = defaultBasics, lang = 'es' } = Astro.props
const { name, label, image, location, profiles, phone, email } = basics
const { city, region } = location
const t = ui[lang as keyof typeof ui]

const SOCIAL_ICONS: SocialIcon = {
  GitHub,
  LinkedIn,
  X,
}

const linkedInfo = profiles.find(({ network }) => network === "LinkedIn")
const linkedUrl = linkedInfo?.url

const printInfo = [email, phone, linkedUrl].filter(Boolean).join(" • ")
const cvFile = lang === 'es' ? "/cv.pdf" : "/cv_en.pdf"
---

<Section>
  <div class="container">
    <div class="info">
      <h1>{name}</h1>
      <h2>{label}</h2>
      <span>
        <WorldMap />
        {city}, {region}
      </span>
      <footer class="print">
        {printInfo}
      </footer>
      <footer class="no-print">
        <a
          href={cvFile}
          title={t['hero.download']}
          download
          class="download-btn-premium"
          data-umami-event="download-cv"
          data-umami-event-lang={lang}
        >
          <Download />
          <span>{lang === 'es' ? 'Descargar CV' : 'Download CV'}</span>
        </a>
        {
          email && (
            <a
              href={`mailto:${email}`}
              title={`${t['hero.mail']} ${name} (${email})`}
              target="_blank"
              rel="noopener noreferrer"
            >
              <Mail />
            </a>
          )
        }
        {
          phone && (
            <>
              <a
                href={`tel:${phone}`}
                title={`${t['hero.phone']} ${name} (${phone})`}
                target="_blank"
                rel="noopener noreferrer"
              >
                <Phone />
              </a>
              <a
                href={`https://wa.me/${phone.replace(/[^0-9]/g, "")}`}
                title={`${t['hero.whatsapp']} ${name}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                <WhatsApp />
              </a>
            </>
          )
        }
        {
          profiles.map(({ network, url }) => {
            const Icon = SOCIAL_ICONS[network as keyof typeof SOCIAL_ICONS]

            return (
              <a
                href={url}
                title={`${t['hero.visit']} ${name} en ${network}`}
                target="_blank"
                rel="noopener noreferrer"
                data-umami-event="visit-social"
                data-umami-event-network={network}
              >
                <Icon />
              </a>
            )
          })
        }
      </footer>
    </div>
    <figure>
      <img src={image} alt={name} />
    </figure>
  </div>
</Section>

<style>
  .download-btn-premium {
    display: inline-flex !important;
    align-items: center !important;
    gap: 0.5rem !important;
    background: var(--bg-page-edge);
    color: var(--text-main) !important;
    padding: 0 0.8rem !important;
    height: 32px !important;
    border-radius: 6px !important;
    font-weight: 600 !important;
    font-size: 0.7rem !important;
    text-decoration: none;
    transition: all 0.2s ease !important;
    border: 1px solid rgba(0, 0, 0, 0.08) !important;
    width: auto !important;
    margin-right: 0.4rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  html.dark .download-btn-premium {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.1) !important;
  }

  .download-btn-premium:hover {
    background: var(--text-main);
    color: var(--bg-page-center) !important;
    border-color: var(--text-main) !important;
  }

  .download-btn-premium svg {
    width: 14px;
    height: 14px;
    stroke: currentColor;
    stroke-width: 2.5;
  }
  .container {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-right: 0;
    flex: 1.5;
  }

  .hero-tags {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 0 1rem;
  }

  .tag {
    background: rgba(var(--bg-page-edge-rgb, 243, 244, 246), 0.5);
    border: 1px solid rgba(0, 0, 0, 0.05);
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    animation: floating-tag 4s infinite ease-in-out;
  }

  .tag:nth-child(2) { animation-delay: -1.5s; }
  .tag:nth-child(3) { animation-delay: -3s; }

  @keyframes floating-tag {
    0%, 100% { transform: translateY(0) rotate(0); }
    50% { transform: translateY(-5px) rotate(1deg); }
  }

  html.dark .tag {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.1);
  }

  h1 {
    font-size: 2rem;
  }

  h2 {
    color: var(--text-muted);
    font-weight: 500;
    font-size: 1.1rem;
    text-wrap: balance;
  }

  figure {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    overflow: hidden;
    margin: 0;
    transition: transform 0.3s ease;
  }

  figure:hover {
    transform: scale(1.05);
  }

  img {
    aspect-ratio: 1 / 1;
    object-fit: cover;
    width: 100%;
    height: 100%;
    border-radius: 50%;
  }

  span {
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.85rem;
    letter-spacing: -0.05rem;
  }

  footer {
    color: var(--text-muted);
    font-size: 0.65rem;
    display: flex;
    gap: 4px;
    margin-top: 8px;
  }

  footer a {
    color: var(--text-muted);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--bg-page-edge);
    padding: 4px;
    height: 32px;
    width: 32px;
    border-radius: 6px;
    transition: all 0.3s ease;
  }

  footer a:hover {
    background: var(--bg-page-edge);
    border: 1px solid var(--bg-page-edge);
  }

  @media (width <= 700px) {
    .container {
      flex-direction: column-reverse;
    }

    .info {
      justify-content: center;
      align-items: center;
      padding-right: 0;
      text-align: center;
    }

    .hero-tags {
        display: none;
    }

    figure {
      display: flex;
      justify-content: center;
      align-items: center;
    }

    h2 {
      text-wrap: balance;
    }

    figure {
      margin: 0 auto;
    }
  }
</style>
