---
import { basics as defaultBasics } from "@cv"
import Section from "@/components/Section.astro"
import Mail from "@/icons/Mail.astro"
import Phone from "@/icons/Phone.astro"
import WhatsApp from "@/icons/WhatsApp.astro"
import X from "@/icons/X.astro"
import LinkedIn from "@/icons/LinkedIn.astro"
import GitHub from "@/icons/GitHub.astro"
import WorldMap from "@/icons/WorldMap.astro"
import Download from "@/icons/Download.astro"
import type { SocialIcon } from "@/types"
import type { Basics } from "@/cv"
import { ui } from "@/i18n"

interface Props {
  basics?: Basics
  lang?: string
}

const { basics = defaultBasics, lang = 'es' } = Astro.props
const { name, label, image, location, profiles, phone, email } = basics
const { city, region } = location
const t = ui[lang as keyof typeof ui]

const SOCIAL_ICONS: SocialIcon = {
  GitHub,
  LinkedIn,
  X,
}

const linkedInfo = profiles.find(({ network }) => network === "LinkedIn")
const linkedUrl = linkedInfo?.url

const printInfo = [email, phone, linkedUrl].filter(Boolean).join(" • ")
const cvFile = lang === 'es' ? "/cv.pdf" : "/cv_en.pdf"
---

<Section>
  <div class="container">
    <div class="info">
      <h1>{name}</h1>
      <h2>{label}</h2>
      <span>
        <WorldMap />
        {city}, {region}
      </span>
      <footer class="print">
        {printInfo}
      </footer>
      <footer class="no-print">
        <a
          href={cvFile}
          title={t['hero.download']}
          download
          class="download-btn-premium"
          data-umami-event="download-cv"
          data-umami-event-lang={lang}
        >
          <Download />
          <span>{lang === 'es' ? 'Descargar CV' : 'Download CV'}</span>
        </a>
        {
          email && (
            <a
              href="#"
              data-copy={email}
              data-type="email"
              title={t['hero.mail'] + ' ' + name}
              class="copy-btn"
            >
              <Mail />
            </a>
          )
        }
        {
          phone && (
            <>
              <a
                href="#"
                data-copy={phone}
                data-type="phone"
                title={t['hero.phone'] + ' ' + name}
                class="copy-btn"
              >
                <Phone />
              </a>
              <a
                href={`https://wa.me/${phone.replace(/[^0-9]/g, "")}`}
                title={`${t['hero.whatsapp']} ${name}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                <WhatsApp />
              </a>
            </>
          )
        }
        {
          profiles.map(({ network, url }) => {
            const Icon = SOCIAL_ICONS[network as keyof typeof SOCIAL_ICONS]

            return (
              <a
                href={url}
                title={`${t['hero.visit']} ${name} en ${network}`}
                target="_blank"
                rel="noopener noreferrer"
                data-umami-event="visit-social"
                data-umami-event-network={network}
              >
                <Icon />
              </a>
            )
          })
        }
      </footer>
    </div>
    <figure>
      <img src={image} alt={name} />
      <canvas class="hero-canvas no-print"></canvas>
    </figure>
  </div>
</Section>

<style>
  .download-btn-premium {
    display: inline-flex !important;
    align-items: center !important;
    gap: 0.5rem !important;
    background: linear-gradient(135deg, rgba(96, 165, 250, 0.1), rgba(167, 139, 250, 0.1));
    color: var(--text-main) !important;
    padding: 0 1.2rem !important;
    height: 34px !important;
    border-radius: 100px !important;
    font-weight: 600 !important;
    font-size: 0.75rem !important;
    text-decoration: none;
    transition: all 0.3s ease !important;
    border: 1px solid rgba(var(--text-main-rgb, 0, 0, 0), 0.1) !important;
    width: auto !important;
    margin-right: 0.6rem;
    text-transform: none;
    animation: delicate-pulse 4s infinite;
  }

  html.dark .download-btn-premium {
    background: linear-gradient(135deg, rgba(96, 165, 250, 0.15), rgba(167, 139, 250, 0.15));
    border-color: rgba(255, 255, 255, 0.1) !important;
  }

  .download-btn-premium:hover {
    background: var(--text-main);
    color: var(--bg-page-center) !important;
    border-color: var(--text-main) !important;
    transform: translateY(-1px);
    animation: none;
  }

  @keyframes delicate-pulse {
    0% { box-shadow: 0 0 0 0 rgba(96, 165, 250, 0.15); }
    70% { box-shadow: 0 0 0 8px rgba(96, 165, 250, 0); }
    100% { box-shadow: 0 0 0 0 rgba(96, 165, 250, 0); }
  }

  .download-btn-premium svg {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    stroke-width: 2.5;
  }
  .container {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-right: 0;
    flex: 1.5;
  }

  .hero-tags {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 0 1rem;
  }

  .tag {
    background: rgba(var(--bg-page-edge-rgb, 243, 244, 246), 0.5);
    border: 1px solid rgba(0, 0, 0, 0.05);
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    animation: floating-tag 4s infinite ease-in-out;
  }

  .tag:nth-child(2) { animation-delay: -1.5s; }
  .tag:nth-child(3) { animation-delay: -3s; }

  @keyframes floating-tag {
    0%, 100% { transform: translateY(0) rotate(0); }
    50% { transform: translateY(-5px) rotate(1deg); }
  }

  html.dark .tag {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.1);
  }

  h1 {
    font-size: 2rem;
  }

  h2 {
    color: var(--text-muted);
    font-weight: 500;
    font-size: 1.1rem;
    text-wrap: balance;
  }

  figure {
    position: relative;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    overflow: visible;
    margin: 0;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
  }

  html.dark figure {
    box-shadow: 0 8px 32px rgba(167, 139, 250, 0.3), 0 0 20px rgba(167, 139, 250, 0.2);
  }

  figure:hover {
    transform: scale(1.05);
  }

  .hero-canvas {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 340px;
    height: 340px;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 5;
  }

  img {
    aspect-ratio: 1 / 1;
    object-fit: cover;
    width: 100%;
    height: 100%;
    border-radius: 50%;
  }

  span {
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.85rem;
    letter-spacing: -0.05rem;
  }

  footer {
    color: var(--text-muted);
    font-size: 0.65rem;
    display: flex;
    gap: 4px;
    margin-top: 8px;
  }

  footer a {
    color: var(--text-muted);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--bg-page-edge);
    padding: 4px;
    height: 32px;
    width: 32px;
    border-radius: 6px;
    transition: all 0.3s ease;
  }

  footer a.copy-btn {
    cursor: copy;
  }

  footer a:hover {
    background: var(--bg-page-edge);
    border: 1px solid var(--bg-page-edge);
  }

  @media (width <= 700px) {
    .container {
      flex-direction: column-reverse;
    }

    .info {
      justify-content: center;
      align-items: center;
      padding-right: 0;
      text-align: center;
    }

    .hero-tags {
        display: none;
    }

    figure {
      display: flex;
      justify-content: center;
      align-items: center;
    }

    h2 {
      text-wrap: balance;
    }

    figure {
      margin: 0 auto;
    }
  }
</style>

<script>
  // Pause all canvas animation if user prefers reduced motion
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    // skip everything — canvas stays empty (transparent overlay)
    throw new Error('reduced-motion');
  }

  const canvas = document.querySelector('.hero-canvas') as HTMLCanvasElement;
  const DPR = window.devicePixelRatio || 1;
  const SIZE = 340;
  canvas.width  = SIZE * DPR;
  canvas.height = SIZE * DPR;
  const ctx = canvas.getContext('2d')!;
  ctx.scale(DPR, DPR);

  const CX = SIZE / 2;   // 170
  const CY = SIZE / 2;   // 170
  const PHOTO_R = 83;    // photo radius + 3px padding

  // ─── helpers ───────────────────────────────────────────────────────────────
  function lerpAngle(cur: number, tgt: number, t: number) {
    let d = tgt - cur;
    while (d >  Math.PI) d -= 2 * Math.PI;
    while (d < -Math.PI) d += 2 * Math.PI;
    return cur + d * t;
  }

  // ─── Firefly ───────────────────────────────────────────────────────────────
  class Firefly {
    x: number; y: number; vx: number; vy: number;
    phase: number; pulseSpeed: number; size: number;
    opacity = 0; targetOpacity = 0;
    trail: {x:number;y:number}[] = [];
    flickerOut = false; flickerTimer = 0;

    constructor() {
      // Spawn anywhere across the full canvas
      this.x = 15 + Math.random() * (SIZE - 30);
      this.y = 15 + Math.random() * (SIZE - 30);
      this.vx = (Math.random()-.5)*.5; this.vy = (Math.random()-.5)*.5;
      this.phase = Math.random()*Math.PI*2;
      this.pulseSpeed = .016 + Math.random()*.026;
      this.size = 2.3 + Math.random()*2;
    }

    update() {
      this.phase += this.pulseSpeed;
      if (this.flickerOut) {
        this.flickerTimer++;
        this.opacity = this.flickerTimer%4<2 ? Math.max(0,this.opacity-.09) : Math.min(this.targetOpacity,this.opacity+.07);
      } else { this.opacity += (this.targetOpacity - this.opacity)*.042; }
      this.vx += (Math.random()-.5)*.052; this.vy += (Math.random()-.5)*.052;
      const spd = Math.hypot(this.vx,this.vy);
      if (spd>.85){this.vx*=.85/spd; this.vy*=.85/spd;}
      // Soft bounce off canvas edges — full canvas roam, no center pull
      const margin = 16;
      if (this.x < margin)        this.vx += .05;
      if (this.x > SIZE - margin) this.vx -= .05;
      if (this.y < margin)        this.vy += .05;
      if (this.y > SIZE - margin) this.vy -= .05;
      this.trail.push({x:this.x,y:this.y});
      if (this.trail.length>10) this.trail.shift();
      this.x+=this.vx; this.y+=this.vy;
    }

    draw() {
      if (this.opacity<.01) return;
      const pulse=.5+.5*Math.sin(this.phase);
      const sz=this.size, a=this.opacity*(.55+.45*pulse);
      // Trail
      this.trail.forEach((pt,i)=>{
        const t=(i+1)/this.trail.length;
        ctx.beginPath(); ctx.arc(pt.x,pt.y,sz*.28*t,0,Math.PI*2);
        ctx.fillStyle=`rgba(253,224,71,${a*t*.18})`; ctx.fill();
      });
      // Layered concentric fills — real bioluminescent effect without shadowBlur
      const pr = 1+pulse*.28;
      ctx.beginPath(); ctx.arc(this.x,this.y,sz*6.5*pr,0,Math.PI*2);
      ctx.fillStyle=`rgba(167,243,208,${a*.055})`; ctx.fill();
      ctx.beginPath(); ctx.arc(this.x,this.y,sz*4.0*pr,0,Math.PI*2);
      ctx.fillStyle=`rgba(253,224,71,${a*.13})`; ctx.fill();
      ctx.beginPath(); ctx.arc(this.x,this.y,sz*2.0*pr,0,Math.PI*2);
      ctx.fillStyle=`rgba(254,249,195,${a*.44})`; ctx.fill();
      ctx.beginPath(); ctx.arc(this.x,this.y,sz*.85*pr,0,Math.PI*2);
      ctx.fillStyle=`rgba(255,255,255,${a*.88})`; ctx.fill();
    }
  }

  // ─── Scene ─────────────────────────────────────────────────────────────────
  let mode: 'day'|'night' = document.documentElement.classList.contains('dark') ? 'night' : 'day';
  let creatures: Firefly[] = [];
  let raf = 0;

  function spawnDay() {
    creatures = [];
  }

  function spawnNight() {
    creatures = Array.from({length: 6}, () => new Firefly());
    creatures.forEach((f, i) => setTimeout(() => { (f as Firefly).targetOpacity = 0.80; }, i * 175 + 80));
  }

  function init() { mode === 'day' ? spawnDay() : spawnNight(); }

  function onThemeChange(newMode: 'day'|'night') {
    if (newMode === mode) return;
    mode = newMode;
    if (newMode === 'day') {
      creatures.forEach(c => { c.flickerOut = true; c.targetOpacity = 0; });
    }
    setTimeout(init, 1800);
  }

  // Pause RAF when hero is off-screen
  const observer = new IntersectionObserver(entries => {
    const visible = entries[0].isIntersecting;
    if (visible && !raf) raf = requestAnimationFrame(loop);
    if (!visible && raf) { cancelAnimationFrame(raf); raf = 0; }
  }, { threshold: 0.1 });
  observer.observe(canvas);

  function loop() {
    ctx.clearRect(0, 0, SIZE, SIZE);
    creatures.forEach(c => { c.update(); c.draw(); });
    raf = requestAnimationFrame(loop);
  }

  init();
  raf = requestAnimationFrame(loop);

  window.addEventListener('theme-changed', (e: Event) => {
    const detail = (e as CustomEvent<{theme:string}>).detail;
    onThemeChange(detail.theme === 'dark' ? 'night' : 'day');
  });
</script>
