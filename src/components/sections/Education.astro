---
import Section from "../Section.astro"
import { ui } from "@/i18n"
import { education as defaultEducation } from "@cv"
import type { Education as EducationType } from "@/cv"

interface Props {
  education?: Array<EducationType>
  lang?: string
}

const { education = defaultEducation, lang = 'es' } = Astro.props
const t = ui[lang as keyof typeof ui]
---

<Section title={t['section.education']}>
  <ul>
    {
      education.map(({ institution, startDate, endDate, area }) => {
        const startYear = new Date(startDate).getFullYear()
        const endYear =
          endDate != null ? (isNaN(Date.parse(endDate)) ? endDate : new Date(endDate).getFullYear()) : t['experience.actual']
        const years = `${startYear} - ${endYear}`

        return (
          <li>
            <article>
              <header>
                <div>
                  <h3>{institution}</h3>
                </div>

                <time>{years}</time>
              </header>

              <footer>
                <p>{area}</p>
              </footer>
            </article>
          </li>
        )
      })
    }
  </ul>
</Section>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  article h3 {
    font-weight: 500;
    color: var(--text-main);
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4px;
  }

  time {
    color: var(--text-muted);
    font-size: 0.85rem;
    min-width: 102px;
  }

  @media (width <= 700px) {
    time {
      text-align: right;
    }
  }
</style>
