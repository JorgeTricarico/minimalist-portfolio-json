---
import Section from "../Section.astro"

import { education } from "@cv"
---

<Section title="Educación">
  <ul>
    {
      education.map(({ institution, startDate, endDate, area, studyType, courses }) => {
        const startYear = new Date(startDate).getFullYear()
        const endYear =
          endDate != null ? new Date(endDate).getFullYear() : "Actual"
        const years = `${startYear} - ${endYear}`

        return (
            <li>
              <article>
                <header>
                  <div>
                    <h3>{institution}</h3>
                  </div>

                  <time>{years}</time>
                </header>

                <footer>
                  <p>{studyType}</p>
                  <p>{area}</p>
                  {courses && courses.length > 0 && (
                    <ul class="education-details">
                      {courses.map(course => (
                        <li set:html={course}></li>
                      ))}
                    </ul>
                  )}
                </footer>
              </article>
            </li>
        )
      })
    }
  </ul>
</Section>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  footer {
    display: flex;
    flex-direction: column;
    gap: 4px;
    color: #444;
    font-size: 0.9rem;
  }

  .education-details {
    list-style-type: disc;
    padding-left: 20px;
    margin-top: 4px;
    font-size: 0.85rem;
    color: #666;
  }

  article h3 {
    font-weight: 500;
    color: #111;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4px;
  }

  time {
    color: #555;
    font-size: 0.85rem;
    min-width: 102px;
  }

  @media (width <= 700px) {
    time {
      text-align: right;
    }
  }
</style>
