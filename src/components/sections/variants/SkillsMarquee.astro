---
import Section from "../../Section.astro"
import { skills } from "@cv"

const CATEGORY_STYLES = {
  "IA & Agentes": { color: "#a78bfa", glow: "rgba(167, 139, 250, 0.5)", bg: "rgba(167, 139, 250, 0.08)" },
  "Testing & QA": { color: "#34d399", glow: "rgba(52, 211, 153, 0.5)", bg: "rgba(52, 211, 153, 0.08)" },
  "Dev & Ops": { color: "#fbbf24", glow: "rgba(251, 191, 36, 0.5)", bg: "rgba(251, 191, 36, 0.08)" },
  "Infra & Cloud": { color: "#60a5fa", glow: "rgba(96, 165, 250, 0.5)", bg: "rgba(96, 165, 250, 0.08)" },
  "Observabilidad & Data": { color: "#fb7185", glow: "rgba(251, 113, 133, 0.5)", bg: "rgba(251, 113, 133, 0.08)" },
  "Idiomas": { color: "#2dd4bf", glow: "rgba(45, 212, 191, 0.5)", bg: "rgba(45, 212, 191, 0.08)" },
  "default": { color: "#9ca3af", glow: "rgba(156, 163, 175, 0.5)", bg: "rgba(156, 163, 175, 0.08)" }
};

const getIconUrl = (name) => {
  const n = name.toLowerCase().trim();
  const map = {
    // Testing
    "playwright": "logos:playwright",
    "cypress": "logos:cypress-icon",
    "selenium": "logos:selenium",
    "appium": "logos:appium",
    "pytest": "logos:pytest",
    "postman": "logos:postman-icon",
    "bruno": "simple-icons:bruno",
    "k6": "simple-icons:k6",
    
    // IA
    "openai": "logos:openai-icon",
    "gemini": "logos:google-gemini",
    "claude": "logos:anthropic-icon",
    "anthropic": "logos:anthropic-icon",
    "deepseek": "simple-icons:deepseek",
    "copilot": "logos:github-copilot",
    "cursor": "simple-icons:cursor",
    "hugging": "logos:hugging-face-icon",
    "langchain": "simple-icons:langchain",
    
    // Dev & Ops
    "python": "logos:python",
    "java": "logos:java",
    "typescript": "logos:typescript-icon",
    "javascript": "logos:javascript",
    "node": "logos:nodejs-icon",
    "fastapi": "logos:fastapi",
    "aws": "logos:aws",
    "azure": "logos:microsoft-azure",
    "docker": "logos:docker-icon",
    "jenkins": "logos:jenkins",
    "linux": "logos:linux-tux",
    "bash": "logos:bash-icon",
    "github actions": "logos:github-actions",
    "ci/cd": "lucide:infinity",
    
    // Data
    "sql": "logos:postgresql",
    "nosql": "logos:mongodb-icon",
    "grafana": "logos:grafana",
    "kibana": "logos:kibana"
  };

  // Prioridad: 1. Coincidencia exacta, 2. Búsqueda de palabra clave, 3. Fallback inteligente
  const foundKey = Object.keys(map).find(key => n.includes(key));
  const iconName = map[n] || (foundKey ? map[foundKey] : null);

  if (iconName) return `https://api.iconify.design/${iconName}.svg`;

  // Fallbacks para conceptos abstractos
  if (n.includes("bot") || n.includes("agente") || n.includes("antigravity")) return "https://api.iconify.design/lucide:bot.svg";
  if (n.includes("engram")) return "https://api.iconify.design/material-symbols:psychology.svg";
  if (n.includes("logs") || n.includes("traces") || n.includes("análisis")) return "https://api.iconify.design/lucide:file-search.svg";
  if (n.includes("idioma") || n.includes("inglés") || n.includes("español")) return "https://api.iconify.design/lucide:languages.svg";
  
  return `https://api.iconify.design/lucide:code-2.svg`;
};
---

<Section title="Habilidades">
  <div class="marquee-wrapper">
    {
      skills.map(({ name, keywords }, index) => {
        const isReverse = index % 2 !== 0;
        const speed = 50 + (index * 20); 
        const style = CATEGORY_STYLES[name] || CATEGORY_STYLES.default;

        return (
          <div class="marquee-row" style={`--duration: ${speed}s; --accent-color: ${style.color}; --accent-glow: ${style.glow}; --accent-bg: ${style.bg}; --delay: ${index * 0.1}s;`}>
            {[1, 2, 3].map(() => (
              <div class={`marquee-content ${isReverse ? 'scroll-reverse' : 'scroll-normal'}`}>
                <div class="category-tag">
                  <span class="dot"></span>
                  {name}
                </div>
                {keywords.map(keyword => (
                  <div class="skill-pill">
                    <div class="shine"></div>
                    <img src={getIconUrl(keyword)} alt="" class="skill-icon" />
                    <span>{keyword}</span>
                  </div>
                ))}
                <span class="row-separator"></span>
              </div>
            ))}
          </div>
        )
      })
    }
  </div>
</Section>

<style>
  .marquee-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    overflow: hidden;
    width: 100%;
    padding-block: 0.5rem;
    mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
  }

  .marquee-row { 
    display: flex; 
    width: max-content; 
    align-items: center; 
    opacity: 0;
    animation: fadeIn 0.8s ease forwards;
    animation-delay: var(--delay);
  }
  
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  .marquee-row:hover .marquee-content { animation-play-state: paused; }

  .marquee-content {
    display: flex;
    gap: 1.2rem;
    align-items: center;
    padding-right: 1.2rem;
    flex-shrink: 0;
  }

  .scroll-normal { animation: scroll-left var(--duration) linear infinite; }
  .scroll-reverse { animation: scroll-right var(--duration) linear infinite; }

  @keyframes scroll-left { from { transform: translateX(0); } to { transform: translateX(-100%); } }
  @keyframes scroll-right { from { transform: translateX(-100%); } to { transform: translateX(0); } }

  .category-tag {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--accent-color);
    background: var(--accent-bg);
    padding: 4px 12px;
    border-radius: 100px;
    border: 1px solid rgba(var(--accent-color), 0.2);
    white-space: nowrap;
    backdrop-filter: blur(4px);
  }

  .dot {
    width: 6px;
    height: 6px;
    background: var(--accent-color);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--accent-color);
  }

  .row-separator {
    width: 30px;
    height: 1px;
    background: var(--accent-color);
    opacity: 0.1;
  }

  .skill-pill {
    background: var(--bg-page-edge);
    border-radius: 10px;
    color: var(--text-main);
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.4rem 0.9rem;
    transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    border: 1px solid rgba(0, 0, 0, 0.04);
    white-space: nowrap;
    position: relative;
    overflow: hidden;
    cursor: default;
  }

  .skill-icon {
    width: 18px;
    height: 18px;
    object-fit: contain;
    transition: all 0.4s ease;
  }

  /* Invertir iconos de Lucide o logos negros cuando no están en hover */
  html.dark .skill-icon {
    /* Algunos logos de Iconify ya vienen con color, pero los de Lucide o simples los invertimos si son negros */
    filter: brightness(1.2);
  }

  .shine {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(120deg, transparent, rgba(255,255,255,0.3), transparent);
    transition: all 0.6s;
  }

  .skill-pill:hover {
    background: var(--accent-color);
    color: white;
    transform: scale(1.1) translateY(-4px);
    box-shadow: 0 12px 25px -8px var(--accent-glow);
    border-color: transparent;
    z-index: 20;
  }

  .skill-pill:hover .shine {
    left: 100%;
    transition: all 0.6s ease-in-out;
  }

  .skill-pill:hover .skill-icon {
    filter: brightness(0) invert(1) !important;
    transform: scale(1.1) rotate(5deg);
  }

  html.dark .skill-pill {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
  }
</style>
