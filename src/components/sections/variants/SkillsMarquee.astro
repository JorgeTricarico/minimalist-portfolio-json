---
import Section from "../../Section.astro"
import { skills } from "@cv"

const CATEGORY_STYLES: Record<string, { color: string, glow: string, bg: string }> = {
  "IA & Agentes": { color: "#a78bfa", glow: "rgba(167, 139, 250, 0.5)", bg: "rgba(167, 139, 250, 0.08)" },
  "Testing & QA": { color: "#34d399", glow: "rgba(52, 211, 153, 0.5)", bg: "rgba(52, 211, 153, 0.08)" },
  "Dev & Ops": { color: "#fbbf24", glow: "rgba(251, 191, 36, 0.5)", bg: "rgba(251, 191, 36, 0.08)" },
  "Infra & Cloud": { color: "#60a5fa", glow: "rgba(96, 165, 250, 0.5)", bg: "rgba(96, 165, 250, 0.08)" },
  "Observabilidad & Data": { color: "#fb7185", glow: "rgba(251, 113, 133, 0.5)", bg: "rgba(251, 113, 133, 0.08)" },
  "Idiomas": { color: "#2dd4bf", glow: "rgba(45, 212, 191, 0.5)", bg: "rgba(45, 212, 191, 0.08)" },
  "default": { color: "#9ca3af", glow: "rgba(156, 163, 175, 0.5)", bg: "rgba(156, 163, 175, 0.08)" }
};

const getIconUrl = (name: string) => {
  const n = name.toLowerCase().trim();
  
  // Iconify Logos (Alta Calidad y estabilidad)
  const logos: Record<string, string> = {
    "javascript": "logos:javascript",
    "typescript": "logos:typescript-icon",
    "postgresql": "logos:postgresql",
    "mongodb": "logos:mongodb-icon",
    "python": "logos:python",
    "java": "logos:java",
    "js": "logos:javascript",
    "ts": "logos:typescript-icon",
    "node": "logos:nodejs-icon",
    "fastapi": "logos:fastapi-icon",
    "aws": "logos:aws",
    "amazon": "logos:aws",
    "azure": "logos:microsoft-azure",
    "docker": "logos:docker-icon",
    "jenkins": "logos:jenkins",
    "github actions": "logos:github-actions",
    "postman": "logos:postman-icon",
    "selenium": "logos:selenium",
    "playwright": "logos:playwright",
    "cypress": "logos:cypress-icon",
    "mysql": "logos:mysql-icon",
    "openai": "logos:openai-icon",
    "chatgpt": "logos:openai-icon",
    "langchain": "logos:langchain-icon",
    "hugging": "logos:hugging-face-icon",
  };

  // Buscar coincidencia más larga primero para evitar colisiones (ej: javascript vs java)
  const foundLogo = Object.keys(logos)
    .sort((a, b) => b.length - a.length)
    .find(key => n.includes(key));
  if (foundLogo) return `https://api.iconify.design/${logos[foundLogo]}.svg`;

  // Simple Icons para el resto
  const simple: Record<string, string> = {
    "playwright": "playwright",
    "cypress": "cypress",
    "appium": "appium",
    "pytest": "pytest",
    "bruno": "bruno",
    "k6": "k6",
    "gemini": "googlegemini",
    "claude": "anthropic",
    "anthropic": "anthropic",
    "deepseek": "deepseek",
    "copilot": "githubcopilot",
    "cursor": "cursor",
    "linux": "linux",
    "bash": "gnubash",
    "supabase": "supabase",
    "nosql": "mongodb",
    "sql": "postgresql",
    "grafana": "grafana",
    "kibana": "kibana"
  };

  const foundSimple = Object.keys(simple)
    .sort((a, b) => b.length - a.length)
    .find(key => n.includes(key));
  if (foundSimple) return `https://cdn.simpleicons.org/${simple[foundSimple]}`;

  // Fallbacks para conceptos abstractos con Iconify lucide/material
  if (n.includes("nosql")) return "https://api.iconify.design/material-symbols:database-off-outline.svg";
  if (n.includes("sql")) return "https://api.iconify.design/material-symbols:database-outline.svg";
  if (n.includes("bot") || n.includes("agente") || n.includes("antigravity") || n.includes("cobrotron") || n.includes("fulltron")) return "https://api.iconify.design/lucide:bot.svg";
  if (n.includes("engram")) return "https://api.iconify.design/ph:brain-duotone.svg";
  if (n.includes("logs") || n.includes("traces") || n.includes("análisis")) return "https://api.iconify.design/lucide:file-search.svg";
  if (n.includes("idioma") || n.includes("inglés") || n.includes("español")) return "https://api.iconify.design/lucide:languages.svg";
  if (n.includes("ci/cd") || n.includes("pipeline")) return "https://api.iconify.design/lucide:infinity.svg";
  if (n.includes("performance") || n.includes("rendimiento")) return "https://api.iconify.design/lucide:gauge.svg";
  
  return "https://api.iconify.design/lucide:code-2.svg";
};
---

<Section title="Habilidades">
  <div class="marquee-wrapper">
    {
      skills.map(({ name, keywords }, index) => {
        const isReverse = index % 2 !== 0;
        const speed = 50 + (index * 20); 
        const style = CATEGORY_STYLES[name] || CATEGORY_STYLES.default;

        // Si hay muy pocos keywords (como Idiomas), los dejamos estáticos para no marear
        const isStatic = keywords.length < 3;

        return (
          <div class={`marquee-row ${isStatic ? 'is-static' : ''}`} style={`--duration: ${speed}s; --accent-color: ${style.color}; --accent-glow: ${style.glow}; --accent-bg: ${style.bg}; --delay: ${index * 0.1}s;`}>
            {isStatic ? (
              <div class="marquee-content">
                <div class="category-tag">
                  {name}
                </div>
                {keywords.map(keyword => (
                  <div class="skill-pill">
                    <div class="shine"></div>
                    <img 
                      src={getIconUrl(keyword)} 
                      alt="" 
                      class="skill-icon" 
                      onerror="this.style.display='none'"
                    />
                    <span>{keyword}</span>
                  </div>
                ))}
              </div>
            ) : (
              [1, 2, 3, 4].map(() => (
                <div class={`marquee-content ${isReverse ? 'scroll-reverse' : 'scroll-normal'}`}>
                  <div class="category-tag">
                    {name}
                  </div>
                  {keywords.map(keyword => (
                    <div class="skill-pill">
                      <div class="shine"></div>
                      <img 
                        src={getIconUrl(keyword)} 
                        alt="" 
                        class="skill-icon" 
                        onerror="this.style.display='none'"
                      />
                      <span>{keyword}</span>
                    </div>
                  ))}
                </div>
              ))
            )}
          </div>
        )
      })
    }
  </div>
</Section>

<style>
  .marquee-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    overflow: hidden;
    width: 100%;
    padding-block: 0.5rem;
    mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
  }

  .marquee-row { 
    display: flex; 
    width: max-content; 
    align-items: center; 
    opacity: 0;
    animation: fadeIn 0.8s ease forwards;
    animation-delay: var(--delay);
  }

  .marquee-row.is-static {
    width: 100%;
    justify-content: center;
    background: linear-gradient(to right, transparent, var(--accent-bg), transparent);
    border-radius: 100px;
    padding-block: 2px;
  }
  
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  .marquee-row:hover .marquee-content { animation-play-state: paused; }

  .marquee-content {
    display: flex;
    gap: 1.2rem;
    align-items: center;
    padding-right: 1.2rem;
    flex-shrink: 0;
  }

  .scroll-normal { animation: scroll-left var(--duration) linear infinite; }
  .scroll-reverse { animation: scroll-right var(--duration) linear infinite; }

  @keyframes scroll-left { from { transform: translateX(0); } to { transform: translateX(-100%); } }
  @keyframes scroll-right { from { transform: translateX(-100%); } to { transform: translateX(0); } }

  .category-tag {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--accent-color);
    background: var(--accent-bg);
    padding: 4px 12px;
    border-radius: 100px;
    border: 1px solid rgba(var(--accent-color), 0.2);
    white-space: nowrap;
    backdrop-filter: blur(4px);
  }


  .skill-pill {
    background: var(--bg-page-edge);
    border-radius: 10px;
    color: var(--text-main);
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.4rem 0.9rem;
    transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    border: 1px solid rgba(0, 0, 0, 0.04);
    white-space: nowrap;
    position: relative;
    overflow: hidden;
    cursor: default;
  }

  .skill-icon {
    width: 18px;
    height: 18px;
    object-fit: contain;
    transition: all 0.4s ease;
  }

  .shine {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(120deg, transparent, rgba(255,255,255,0.3), transparent);
    transition: all 0.6s;
  }

  .skill-pill:hover {
    background: var(--accent-color);
    color: white;
    transform: scale(1.1) translateY(-4px);
    box-shadow: 0 12px 25px -8px var(--accent-glow);
    border-color: transparent;
    z-index: 20;
  }

  .skill-pill:hover .shine {
    left: 100%;
    transition: all 0.6s ease-in-out;
  }

  .skill-pill:hover .skill-icon {
    filter: brightness(0) invert(1) !important;
    transform: scale(1.1) rotate(5deg);
  }

  html.dark .skill-pill {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
  }
</style>
