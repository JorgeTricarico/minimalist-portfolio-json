---
import GitHub from "@/icons/GitHub.astro"
import Section from "../Section.astro"
import { ui } from "@/i18n"
import { projects as defaultProjects } from "@cv"
import type { Projects as ProjectsType } from "@/cv"

interface Props {
  projects?: Array<ProjectsType>
  lang?: string
}

const { projects = defaultProjects, lang = 'es' } = Astro.props
const t = ui[lang as keyof typeof ui]
---

<Section title={t['section.projects']}>
  <ul>
    {
      projects.map(
        ({ url, description, highlights, name, isActive, github, image, imageLight, imageDark }) => {
          return (
            <li>
              <article>
                <header>
                  <div class="project-header">
                    <h3>
                      <a href={url} target="_blank" title={`${t['projects.visit']} ${name}`}>
                        {name}
                      </a>
                      {isActive && <span>&bull;</span>}
                    </h3>
                    {github && (
                      <a
                        class="github-code-link"
                        href={github}
                        target="_blank"
                        title={t['projects.visit']}
                      >
                        <GitHub />
                      </a>
                    )}
                  </div>
                  {(imageLight || imageDark || image) && (
                    <figure class="project-img">
                      {imageLight && <img src={imageLight} alt={name} class="light-only" />}
                      {imageDark && <img src={imageDark} alt={name} class="dark-only" />}
                      {image && !imageLight && !imageDark && <img src={image} alt={name} />}
                    </figure>
                  )}
                  <p>{description}</p>
                </header>
                <footer>
                  {highlights.map((highlight) => {
                    return <span>{highlight}</span>
                  })}
                </footer>
              </article>
            </li>
          )
        }
      )
    }
  </ul>
</Section>

<style>
  ul {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
    margin-inline: -16px;
  }

  article {
    position: relative;
    border-radius: 8px;
    border: 1px solid var(--bg-page-edge);
    gap: 16px;
    display: flex;
    flex-direction: column;
    padding: 16px;
    height: 100%;
    transition: all 0.3s ease;
    overflow: hidden;
  }

  article:hover {
    border-color: var(--text-muted);
  }

  .project-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
    position: relative;
    z-index: 20; /* Keep it above the terminal */
  }

  .project-img {
    width: 100%;
    height: 160px;
    overflow: hidden;
    border-radius: 6px;
    margin-bottom: 12px;
    border: 1px solid var(--bg-page-edge);
    background: var(--bg-page-edge);
  }

  .project-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform 0.5s ease;
  }

  .dark-only {
    display: none;
  }

  :global(html.dark) .dark-only {
    display: block;
  }

  :global(html.dark) .light-only {
    display: none;
  }

  article:hover .project-img img {
    transform: scale(1.05);
  }

  .terminal-header {
    display: flex;
    gap: 4px;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .red { background: #ff5f56; }
  .yellow { background: #ffbd2e; }
  .green { background: #27c93f; }

  .terminal-body {
    font-size: 0.65rem;
    line-height: 1.4;
    color: #c9d1d9;
  }

  .terminal-cmd { color: #58a6ff; }
  .terminal-success { color: #3fb950; }
  .terminal-info { color: #8b949e; }
  
  .terminal-cursor {
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    from, to { opacity: 1; }
    50% { opacity: 0; }
  }

  article header {
    flex: 1;
  }

  article h3 {
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  article a {
    color: var(--text-main);
  }

  article a:hover {
    text-decoration: underline;
  }

  article p {
    font-size: 0.75rem;
    line-height: 1.2rem;
    margin-bottom: 4px;
  }

  article h3 span {
    color: rgb(0, 188, 47);
    animation-name: flicker;
    animation-duration: 3s;
    animation-timing-function: ease-in;
    animation-iteration-count: infinite;
  }

  footer {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    font-size: 0.6rem;
  }

  footer span {
    border-radius: 6px;
    background: var(--bg-page-edge);
    color: var(--text-muted);
    font-size: 0.6rem;
    font-weight: 500;
    padding: 0.2rem 0.6rem;
    border: 1px solid rgba(0, 0, 0, 0.05);
  }

  .github-code-link {
    margin-left: 5px;
  }

  @keyframes flicker {
    0% { opacity: 1; }
    50% { opacity: 0.25; }
    100% { opacity: 1; }
  }

  @media (width <= 700px) {
    ul {
      margin-inline: 0px;
    }
  }

  @media print {
    footer span {
      border: 1px solid #ccc;
    }
  }
</style>
