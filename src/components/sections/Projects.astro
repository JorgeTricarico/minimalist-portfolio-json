---
import GitHub from "@/icons/GitHub.astro"
import Section from "../Section.astro"
import { ui } from "@/i18n"
import { projects as defaultProjects } from "@cv"
import type { Projects as ProjectsType } from "@/cv"

interface Props {
  projects?: Array<ProjectsType>
  lang?: string
}

const { projects = defaultProjects, lang = 'es' } = Astro.props
const t = ui[lang as keyof typeof ui]
---

<Section title={t['section.projects']}>
  <ul>
    {
      projects.map(
        ({ url, description, highlights, name, isActive, github }) => {
          return (
            <li>
              <article>
                <header>
                  <h3>
                    <a href={url} target="_blank" title={`${t['projects.visit']} ${name}`}>
                      {name}
                    </a>
                    {isActive && <span>&bull;</span>}
                    {github && (
                      <a
                        class="github-code-link"
                        href={github}
                        target="_blank"
                        title={t['projects.visit']}
                      >
                        <GitHub />
                      </a>
                    )}
                  </h3>
                  <p>{description}</p>
                </header>
                <footer>
                  {highlights.map((highlight) => {
                    return <span>{highlight}</span>
                  })}
                </footer>
              </article>
            </li>
          )
        }
      )
    }
  </ul>
</Section>

<style>
  ul {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
    margin-inline: -16px;
  }

  article {
    border-radius: 8px;
    border: 1px solid var(--bg-page-edge);
    gap: 16px;
    display: flex;
    flex-direction: column;
    padding: 16px;
    height: 100%;
    transition: all 0.3s ease;
  }

  article:hover {
    background: var(--bg-page-edge);
    border-color: var(--text-muted);
  }

  article header {
    flex: 1;
  }

  article h3 {
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  article a {
    color: var(--text-main);
  }

  article a:hover {
    text-decoration: underline;
  }

  article p {
    font-size: 0.75rem;
    line-height: 1.2rem;
    margin-bottom: 4px;
  }

  article h3 span {
    color: rgb(0, 188, 47);
    animation-name: flicker;
    animation-duration: 3s;
    animation-timing-function: ease-in;
    animation-iteration-count: infinite;
  }

  footer {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    font-size: 0.6rem;
  }

  footer span {
    border-radius: 6px;
    background: var(--bg-page-edge);
    color: var(--text-muted);
    font-size: 0.6rem;
    font-weight: 500;
    padding: 0.2rem 0.6rem;
    border: 1px solid rgba(0, 0, 0, 0.05);
  }

  .github-code-link {
    margin-left: 5px;
  }

  @keyframes flicker {
    0% { opacity: 1; }
    50% { opacity: 0.25; }
    100% { opacity: 1; }
  }

  @media (width <= 700px) {
    ul {
      margin-inline: 0px;
    }
  }

  @media print {
    footer span {
      border: 1px solid #ccc;
    }
  }
</style>
